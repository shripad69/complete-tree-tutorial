// logic 
    // just focus that if path sum is negative then send 0 instead of it 

#include <bits/stdc++.h>
using namespace std;

struct TreeNode {
    int val;
    TreeNode *left;
    TreeNode *right;
    TreeNode() : val(0), left(nullptr), right(nullptr) {}
    TreeNode(int x) : val(x), left(nullptr), right(nullptr) {}
    TreeNode(int x, TreeNode *left, TreeNode *right) : val(x), left(left), right(right) {}
};

class Solution {
public:
    int sum = INT_MIN;

    int dfs(TreeNode* node) {
        if (!node) return 0;

        // if somthing negative comes igonre it and take zero
        int l = max(0, dfs(node->left));
        int r = max(0, dfs(node->right));

        // update the sum with node val + left + right
        sum = max(sum, node->val + l + r);

        // return node val + max of the left or right
        return node->val + max(l, r);
    }

    int maxPathSum(TreeNode* root) {
        dfs(root);
        return sum;
    }
};